<div
  id="pincode-validator-widget-{{ block.id }}"
  class="pv-widget"
  data-pincode-validator
  data-block-id="{{ block.id }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id | default: '' }}"
  data-endpoint="/apps/pincode-validator/validate"
>
  <div class="pv-widget__heading">
    {{ block.settings.heading | escape }}
  </div>

  {% if block.settings.description != blank %}
    <div class="pv-widget__description">
      {{ block.settings.description | escape }}
    </div>
  {% endif %}

  <div class="pv-widget__form">
    <label
      class="pv-visually-hidden"
      for="pincode-input-{{ block.id }}"
    >
      Delivery pincode
    </label>

    <input
      id="pincode-input-{{ block.id }}"
      class="pv-widget__input"
      type="text"
      inputmode="numeric"
      autocomplete="postal-code"
      maxlength="6"
      pattern="[1-9][0-9]{5}"
      placeholder="{{ block.settings.placeholder | escape }}"
      aria-describedby="pincode-result-{{ block.id }}"
      data-pincode-input
    >

    <button
      class="pv-widget__button"
      type="button"
      data-pincode-submit
    >
      <span data-pincode-button-text>
        {{ block.settings.button_label | escape }}
      </span>

      <span
        class="pv-widget__spinner"
        data-pincode-spinner
        aria-hidden="true"
      ></span>
    </button>
  </div>

  <div
    id="pincode-result-{{ block.id }}"
    class="pv-widget__result"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    data-pincode-result
  ></div>

  <noscript>
    <p class="pv-widget__noscript">
      JavaScript is required to check delivery availability.
    </p>
  </noscript>
</div>

{% schema %}
{
  "name": "Pincode Validator",
  "target": "section",
  "stylesheet": "pincode-validator.css",
  "javascript": "pincode-validator.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check delivery availability"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Enter your pincode to check delivery time and payment options."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter pincode"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Check"
    }
  ]
}
{% endschema %}