// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}


model Shop {
  id         String          @id @default(cuid())
  shopDomain String          @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  selectedPlan   String?
  planSelectedAt DateTime?

  settings   AppSetting?
  pincodes   Pincode[]
  logs       ValidationLog[]
}

model AppSetting {
  id                  String   @id @default(cuid())
  shopId              String   @unique

  restrictAddToCart   Boolean  @default(true)
  restrictBuyNow      Boolean  @default(true)
  enableEmbed         Boolean  @default(true)
  enableBlock         Boolean  @default(true)
  requireValidation   Boolean  @default(true)

  successMessage      String   @default("Delivery available for this pincode.")
  failureMessage      String   @default("Sorry, delivery is not available for this pincode.")

  defaultCountry      String?
  rememberPincodeDays Int      @default(7)

  popupEnabled        Boolean  @default(false)

  popupTitle          String   @default("Check Delivery Availability")
  popupDescription    String   @default("Enter your pincode to check delivery availability.")
  popupButtonText     String   @default("Check Availability")
  popupLocationText   String   @default("Use my current location")

  popupTrigger        String   @default("delay")
  popupDelaySeconds   Int      @default(3)

  popupRemember       Boolean  @default(true)
  popupRememberDays   Int      @default(7)

  popupShowClose      Boolean  @default(true)
  popupCloseOnOverlay Boolean  @default(true)

  popupTheme          String   @default("light")
  popupWidth          Int      @default(420)

  popupShowHome       Boolean  @default(true)
  popupShowProduct    Boolean  @default(true)
  popupShowCollection Boolean  @default(true)
  popupShowCart       Boolean  @default(false)
  popupShowPages      Boolean  @default(false)

  popupAutoClose      Boolean  @default(true)
  popupAutoCloseDelay Int      @default(1500)

  locationDetectionEnabled Boolean @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Pincode {
  id               String   @id @default(cuid())
  shopId           String
  pincode          String
  city             String?
  state            String?
  country          String?
  codAvailable     Boolean  @default(false)
  prepaidAvailable Boolean  @default(true)
  estDeliveryDays  Int?
  isActive         Boolean  @default(true)
  source           String   @default("manual")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, pincode])
  @@index([shopId, pincode])
}

model ValidationLog {
  id               String   @id @default(cuid())
  shopId           String
  pincode          String

  city             String?
  state            String?
  country          String?

  productId        String?
  productHandle    String?
  productTitle     String?

  codAvailable     Boolean  @default(false)
  prepaidAvailable Boolean  @default(false)
  estDeliveryDays  Int?

  result           String
  isAvailable      Boolean  @default(false)

  source           String   @default("storefront")
  userAgent        String?

  createdAt        DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, pincode])
  @@index([shopId, createdAt])
  @@index([shopId, isAvailable])
  @@index([shopId, result])
}
